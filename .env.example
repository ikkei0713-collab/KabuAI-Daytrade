# KabuAI-Daytrade Environment Variables
# Copy this file to .env and fill in your values.
# All variables are prefixed with KABUAI_ in the environment.

# ── Safety ──────────────────────────────────────────────────
KABUAI_ALLOW_LIVE_TRADING=False
KABUAI_PAPER_TRADING=True

# ── Paths (usually no need to change) ──────────────────────
# KABUAI_BASE_DIR=~/dev/KabuAI-Daytrade
# KABUAI_DB_PATH=~/dev/KabuAI-Daytrade/db/kabuai.db
# KABUAI_LOG_DIR=~/dev/KabuAI-Daytrade/logs

# ── J-Quants API ───────────────────────────────────────────
KABUAI_JQUANTS_MAIL=
KABUAI_JQUANTS_PASSWORD=
KABUAI_JQUANTS_REFRESH_TOKEN=

# ── Trading Parameters ─────────────────────────────────────
KABUAI_MAX_POSITIONS=5
KABUAI_MAX_POSITION_SIZE=500000
KABUAI_TOTAL_CAPITAL=3000000
KABUAI_MAX_LOSS_PER_DAY=-50000
KABUAI_MAX_HOLDING_MINUTES=360

# ── Market Hours (JST) ─────────────────────────────────────
KABUAI_MARKET_OPEN=09:00
KABUAI_MARKET_CLOSE=15:00
KABUAI_PRE_MARKET_SCAN=08:30
KABUAI_FORCE_CLOSE_TIME=14:50

# ── Strategy ────────────────────────────────────────────────
KABUAI_MIN_CONFIDENCE=0.6
KABUAI_STRATEGY_SCORE_THRESHOLD=0.5

# ── Tachibana Securities API ───────────────────────────────
KABUAI_TACHIBANA_API_URL=
KABUAI_TACHIBANA_USER=
KABUAI_TACHIBANA_PASSWORD=

# ── Novaquity Event Intelligence (補助レイヤー) ────────────
# 主戦略は vwap_reclaim のまま。Novaquity は watchlist 加点と confidence 補助に限定。
NOVAQUITY_ENABLED=false
NOVAQUITY_API_KEY=
NOVAQUITY_BASE_URL=https://api.novaquity.com/v1
